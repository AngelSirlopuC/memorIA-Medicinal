# ===== MemorIA Medicinal — configuración =====
# Copia este archivo a .env y ajusta los valores.
# IMPORTANTE: no pongas comentarios en la MISMA línea de una variable.
# En .env el comentario NO se recorta: pasaría a formar parte del valor.

# --- Base de datos (debe coincidir con docker-compose.yml) ---
POSTGRES_USER=memoria
POSTGRES_PASSWORD=memoria
POSTGRES_DB=memoria
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Orígenes permitidos para el frontend (CORS), separados por coma
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost

# --- Almacenamiento ---
# Backend: local | supabase | s3 | minio
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=/data/images

# --- IA (modo OpenAI-first: despliegue simple, solo necesitas la API key) ---
OPENAI_API_KEY=sk-...
# Modelo de visión (extracción de datos + re-rank visual)
VISION_MODEL=gpt-5-mini
# Modelo de embeddings (1536 dims)
EMBED_MODEL=text-embedding-3-small
# Candidatos que pasan al re-rank de Vision
VISION_RERANK_TOPK=5

# --- Telegram (Sprint 2) ---
# Token del bot (lo da @BotFather). Si está vacío, el canal queda deshabilitado.
TELEGRAM_BOT_TOKEN=
# Secret opcional para validar el header del webhook (recomendado en producción)
TELEGRAM_WEBHOOK_SECRET=

# --- WhatsApp Cloud API (Sprint 7) ---
# Token de acceso de la app de Meta
WHATSAPP_TOKEN=
# ID del número de teléfono (Cloud API)
WHATSAPP_PHONE_ID=
# Cadena que defines tú; debe coincidir con la del panel de Meta al configurar el webhook
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
