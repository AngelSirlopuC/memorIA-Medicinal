# ===== MemorIA Medicinal — configuración =====
# Copia este archivo a .env y ajusta los valores.

# --- Base de datos (debe coincidir con docker-compose.yml) ---
POSTGRES_USER=memoria
POSTGRES_PASSWORD=memoria
POSTGRES_DB=memoria
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Orígenes permitidos para el frontend (CORS), separados por coma
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost

# --- Almacenamiento ---
# local | supabase | s3 | minio
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=/data/images

# --- IA (modo OpenAI-first: despliegue simple, solo necesitas la API key) ---
OPENAI_API_KEY=sk-...
VISION_MODEL=gpt-5-mini              # extracción de datos + re-rank visual
EMBED_MODEL=text-embedding-3-small   # 1536 dims
VISION_RERANK_TOPK=5                 # candidatos que pasan al re-rank de Vision

# --- Telegram (Sprint 2) ---
# Token del bot (lo da @BotFather). Si está vacío, el canal queda deshabilitado.
TELEGRAM_BOT_TOKEN=
# Secret opcional para validar el header del webhook (recomendado en producción)
TELEGRAM_WEBHOOK_SECRET=

# --- WhatsApp Cloud API (Sprint 7) ---
WHATSAPP_TOKEN=                 # token de acceso de la app de Meta
WHATSAPP_PHONE_ID=             # ID del número de teléfono (Cloud API)
WHATSAPP_VERIFY_TOKEN=         # cadena que defines tú; debe coincidir al configurar el webhook
WHATSAPP_API_VERSION=v21.0
